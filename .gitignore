# .gitignore

# ─── 依存関係 & 環境変数 ───
# OS固有の依存関係フォルダや、仮想環境フォルダ
*/venv/
/env/
.env

# ─── Pythonのキャッシュと一時ファイル ───
# Pythonが自動生成するキャッシュファイルやコンパイル済みファイル
__pycache__/
*.pyc
*.pyo
*.pyd

# ─── プロジェクト固有の生成ファイル ───
# このリポジトリのプログラムを実行することで生成されるデータファイル
*.csv

# ─── 画像ファイル ───
# プロジェクトで扱う個人情報を含む可能性のある画像ファイル
# 実行結果のデモ用GIFなど、リポジトリに含めたいものは別途git add -fで追加
*.jpg
*.jpeg
*.png
*.gif

# ─── テキストファイル ───
# プロジェクトで扱う個人情報を含む可能性のあるテキストファイル
knowledge.txt

# ─── エディタ/IDEの設定ファイル ───
# VSCodeなどのエディタが自動生成する設定フォルダ
.vscode/
.idea/